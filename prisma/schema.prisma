generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(cuid())
  fullName           String
  email              String              @unique
  phone              String
  country            String
  countryCode        String
  city               String
  address            String
  postalCode         String
  passwordHash       String
  role               UserRole            @default(CUSTOMER)
  emailVerified      Boolean             @default(false)
  isActive           Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  lastLoginAt        DateTime?
  accounts           Account[]
  auditLogs          AuditLog[]
  reviewedDocuments  Document[]          @relation("DocumentReviewer")
  documents          Document[]          @relation("UserDocuments")
  emailVerifications EmailVerification[]
  loanApplications   LoanApplication[]
  loginAttempts      LoginAttempt[]
  notifications      Notification[]
  passwordResets     PasswordReset[]
  sessions           Session[]
  transactions       Transaction[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  depositRequests DepositRequest[]
  physicalCardRequests PhysicalCardRequest[]
  pushSubscriptions PushSubscription[]
}

model EmailVerification {
  id        String             @id @default(cuid())
  userId    String
  email     String
  code      String
  status    VerificationStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([code])
  @@index([status])
  @@index([expiresAt])
}

model PasswordReset {
  id        String             @id @default(cuid())
  userId    String
  email     String
  code      String
  status    VerificationStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([code])
  @@index([status])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  success   Boolean  @default(false)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([email])
  @@index([success])
  @@index([createdAt])
}

model LoanApplication {
  id             String              @id @default(cuid())
  userId         String
  amount         Float
  durationMonths Int
  annualRate     Float
  monthlyPayment Float
  totalAmountDue Float
  totalInterest  Float
  purpose        String?
  status         LoanStatus          @default(DRAFT)
  submittedAt    DateTime?
  approvedAt     DateTime?
  rejectedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  creditDecision CreditDecision?
  documents      Document[]
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers         LoanOffer[]
  payments       LoanPayment[]
  statusHistory  LoanStatusHistory[]
  riskAssessment RiskAssessment?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model LoanOffer {
  id                String          @id @default(cuid())
  loanApplicationId String
  amount            Float
  durationMonths    Int
  annualRate        Float
  monthlyPayment    Float
  totalAmountDue    Float
  accepted          Boolean         @default(false)
  expiresAt         DateTime
  createdAt         DateTime        @default(now())
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id], onDelete: Cascade)

  @@index([loanApplicationId])
  @@index([accepted])
}

model LoanPayment {
  id                String          @id @default(cuid())
  loanApplicationId String
  amount            Float
  dueDate           DateTime
  paidAt            DateTime?
  status            PaymentStatus   @default(PENDING)
  createdAt         DateTime        @default(now())
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id], onDelete: Cascade)

  @@index([loanApplicationId])
  @@index([status])
  @@index([dueDate])
}

model Document {
  id                String           @id @default(cuid())
  userId            String
  loanApplicationId String?
  type              String
  fileUrl           String
  fileName          String
  status            DocumentStatus   @default(PENDING)
  rejectionReason   String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  reviewComment     String?
  reviewedAt        DateTime?
  reviewedById      String?
  loanApplication   LoanApplication? @relation(fields: [loanApplicationId], references: [id])
  reviewedBy        User?            @relation("DocumentReviewer", fields: [reviewedById], references: [id])
  user              User             @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loanApplicationId])
  @@index([status])
  @@index([reviewedById])
  @@index([reviewedAt])
  @@index([createdAt])
}

model PartnerBank {
  id        String   @id @default(cuid())
  name      String
  country   String
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([country])
  @@index([isActive])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model LoanStatusHistory {
  id                String          @id @default(cuid())
  loanApplicationId String
  status            LoanStatus
  note              String?
  createdAt         DateTime        @default(now())
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id], onDelete: Cascade)

  @@index([loanApplicationId])
  @@index([status])
}

model CreditDecision {
  id                String          @id @default(cuid())
  loanApplicationId String          @unique
  score             Int?
  decision          String
  reason            String?
  createdAt         DateTime        @default(now())
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id], onDelete: Cascade)
}

model RiskAssessment {
  id                String          @id @default(cuid())
  loanApplicationId String          @unique
  riskLevel         String
  riskScore         Int?
  notes             String?
  createdAt         DateTime        @default(now())
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entity])
}

model Country {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  phoneCode String
  currency  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Currency {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  symbol    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Account {
  id               String        @id @default(cuid())
  userId           String
  name             String
  type             String        @default("MAIN")
  currency         String        @default("EUR")
  balance          Float         @default(0)
  availableBalance Float         @default(0)
  blockedBalance   Float         @default(0)
  iban             String?       @unique
  bic              String?
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  depositRequests DepositRequest[]
}

model Transaction {
  id              String               @id @default(cuid())
  userId          String
  accountId       String?
  amount          Float
  currency        String               @default("EUR")
  title           String
  description     String?
  reference       String?              @unique
  createdAt       DateTime             @default(now())
  beneficiaryBic  String?
  beneficiaryIban String?
  beneficiaryName String?
  type            TransactionType
  direction       TransactionDirection
  status          TransactionStatus    @default(COMPLETED)
  account         Account?             @relation(fields: [accountId], references: [id])
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
  @@index([type])
  @@index([direction])
  @@index([status])
  @@index([createdAt])
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("TEXT")
  group     String   @default("GENERAL")
  label     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([group])
}

enum UserRole {
  CUSTOMER
  ADMIN
  AGENT
}

enum VerificationStatus {
  PENDING
  VERIFIED
  EXPIRED
}

enum LoanStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  FUNDED
  CLOSED
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  LATE
}

enum NotificationType {
  EMAIL
  SMS
  SYSTEM
}

enum TransactionType {
  TRANSFER
  LOAN
  LOAN_DISBURSEMENT
  LOAN_REPAYMENT
  DEPOSIT
  WITHDRAWAL
  CARD_PAYMENT
  CARD_REFUND
  BANK_FEE
  INTEREST
}

enum TransactionDirection {
  IN
  OUT
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model DepositRequest {
  id             String   @id @default(cuid())
  userId         String
  accountId      String?
  amount         Float
  currency       String   @default("EUR")
  method         String
  status         String   @default("PENDING")
  reference      String   @unique
  proofFileName  String?
  proofFileUrl   String?
  adminNote      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  reviewedAt     DateTime?

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account        Account? @relation(fields: [accountId], references: [id])

  @@index([userId])
  @@index([accountId])
  @@index([status])
  @@index([method])
  @@index([createdAt])
}

model PhysicalCardRequest {
  id              String   @id @default(cuid())
  userId          String
  cardNumber      String?
  maskedNumber    String?
  expiry          String?
  cvv             String?
  status          String   @default("REQUESTED")
  country         String
  city            String
  deliveryAddress String
  adminNote       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  activatedAt     DateTime?
  deliveredAt     DateTime?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh     String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}